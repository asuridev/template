{
  "name": "template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build --configuration production",
    "serve:ssr": "node dist/template/server/server.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:template": "node dist/template/server/server.mjs",
    "dev": "concurrently -n BUILD,SERVER -c cyan,green --kill-others-on-fail \"ng build --watch --configuration development\" \"node --watch dist/template/server/server.mjs\"",
    "dev:start": "ng build --configuration development && npm run dev"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.22",
    "@angular/compiler": "^19.2.22",
    "@angular/core": "^19.2.22",
    "@angular/forms": "^19.2.22",
    "@angular/platform-browser": "^19.2.22",
    "@angular/platform-browser-dynamic": "^19.2.22",
    "@angular/platform-server": "^19.2.22",
    "@angular/router": "^19.2.22",
    "@angular/ssr": "^19.2.25",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "file-type": "^22.0.1",
    "isomorphic-dompurify": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "keycloak-angular": "^19.0.2",
    "keycloak-js": "^25.0.6",
    "multer": "^2.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.25",
    "@angular/cli": "^19.2.25",
    "@angular/compiler-cli": "^19.2.22",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^18.18.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.7.2"
  }
}
